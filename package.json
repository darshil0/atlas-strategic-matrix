{
  "name": "atlas-strategic-agent",
  "version": "3.5.1",
  "type": "module",
  "description": "Enterprise-grade autonomous strategic orchestrator with multi-agent collaborative synthesis.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
